# --- proxy-service (data plane) ---
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# E2B hostname: 8765-sb-abc123.sndbx.com
SANDBOX_DOMAIN=sndbx.com
SANDBOX_INGRESS_DEBUG=false

# api-service in the same namespace
CONTROL_PLANE_URL=http://api-service:8000
CONTROL_PLANE_API_KEY=test-key-12345

# One pod per sandbox; guest port == Service targetPort (no Docker publish).
K8S_NAMESPACE=sandboxes
K8S_POD_SERVICE_TEMPLATE=sandbox-{sandbox_id}.{namespace}.svc.cluster.local
UPSTREAM_RESOLVE_MODE=k8s_dns

# Optional nginx → proxy shared secret (Layer 2)
# INGRESS_ACCESS_TOKEN=
