# =============================================================================
# api-service (control plane) — pairs with ../proxy_service/
# =============================================================================

HOST=0.0.0.0
PORT=8000
API_KEY=test-key-12345
API_SERVICE_ROLE=control
LOG_LEVEL=INFO
DATABASE_URL=postgresql://prism:prism@localhost:5432/prism

# Docker/runc or Docker/runsc sandboxes, executed by runtime-gateway shards.
SANDBOX_ENGINE=docker
SANDBOX_RUNTIME=docker
SANDBOX_ISOLATION=docker
SANDBOX_DOCKER_OCI_RUNTIME=
TEMPLATE_DOCKERFILE_BUILD_MODE=docker_cli
TEMPLATE_BUILD_VIA_RUNTIME_GATEWAY=true
RUNTIME_GATEWAY_URL=http://runtime-gateway.sandboxes.svc.cluster.local:8080
RUNTIME_GATEWAY_NAMESPACE=sandboxes
RUNTIME_GATEWAY_SHARD_COUNT=3
RUNTIME_GATEWAY_STATEFULSET_NAME=runtime-gateway
RUNTIME_GATEWAY_HEADLESS_SERVICE=runtime-gateway-headless
RUNTIME_GATEWAY_SERVICE_PORT=8080

# Data plane URLs returned to clients (routed by runtime-gateway + ingress).
SANDBOX_DATA_PLANE_ENABLED=true
SANDBOX_DATA_PLANE_DOMAIN=sndbx.com
SANDBOX_DATA_PLANE_SCHEME=https
SANDBOX_DATA_PLANE_DEBUG=false
SANDBOX_DEFAULT_ALLOW_PUBLIC_TRAFFIC=false
SANDBOX_WARM_POOL_SIZE=2
# Guest services (user workload ports come from metadata.guest_ports / template env PORT).
ENVD_ALWAYS_ON=true
ENVD_AUTO_START=true
ENVD_PUBLISH_PORT=false
ENVD_PORT=49983

# Optional: template builds still use Docker when DOCKER_HOST is set.
# DOCKER_HOST=unix:///var/run/docker.sock
