# Copy to secrets.yaml, set a strong API_KEY, then: kubectl apply -f deploy/k8s/secrets.yaml
apiVersion: v1
kind: Secret
metadata:
  name: sandbox-secrets
  namespace: sandboxes
type: Opaque
stringData:
  API_KEY: "change-me-before-apply"
  CONTROL_PLANE_API_KEY: "change-me-before-apply"
  INGRESS_ACCESS_TOKEN: "change-me-before-apply"
