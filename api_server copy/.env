# =============================================================================
# api-service (control plane) — pairs with ../proxy_service/
# =============================================================================

HOST=0.0.0.0
PORT=8000
API_KEY=test-key-12345
API_SERVICE_ROLE=control
LOG_LEVEL=INFO
DATABASE_PATH=/var/lib/api/sandboxes.db

# Kubernetes sandboxes (default). Declare ports via metadata.guest_ports or template env PORT.
SANDBOX_ENGINE=k8s
SANDBOX_RUNTIME=k8s
K8S_NAMESPACE=sandboxes
K8S_POD_SERVICE_TEMPLATE=sandbox-{sandbox_id}.{namespace}.svc.cluster.local
K8S_POD_READY_TIMEOUT_SEC=180

# Data plane URLs returned to clients (routed by proxy-service + nginx ingress).
SANDBOX_DATA_PLANE_ENABLED=true
SANDBOX_DATA_PLANE_DOMAIN=sndbx.com
SANDBOX_DATA_PLANE_SCHEME=https
SANDBOX_DATA_PLANE_DEBUG=false
SANDBOX_DEFAULT_ALLOW_PUBLIC_TRAFFIC=false

# Guest services (user workload ports come from metadata.guest_ports / template env PORT).
ENVD_ALWAYS_ON=true
ENVD_AUTO_START=true
ENVD_PUBLISH_PORT=false
ENVD_PORT=49983

# Optional: template builds still use Docker when DOCKER_HOST is set.
# DOCKER_HOST=unix:///var/run/docker.sock

# --- Local Docker dev (disable K8s) ---
# SANDBOX_ENGINE=docker
# SANDBOX_RUNTIME=docker
# SANDBOX_DATA_PLANE_DEBUG=true
# SANDBOX_DATA_PLANE_HTTP_PORT=8080
# SANDBOX_DATA_PLANE_SCHEME=http
